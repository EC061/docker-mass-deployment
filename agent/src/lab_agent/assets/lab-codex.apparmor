#include <tunables/global>

profile lab-codex flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>

  network,
  capability,
  file,
  signal,
  ptrace (readby, tracedby),
  deny /proc/sys/** wklx,
  deny /proc/sysrq-trigger rwklx,
  deny /proc/kcore rwklx,
  deny /proc/kmem rwklx,
  deny /proc/mem rwklx,
  deny /proc/tty/driver/** rwklx,
  # Docker systempaths=unconfined removes runc's /proc overmounts so bubblewrap can mount a fresh
  # procfs. Preserve the read masks and read-only system-path policy here without mountpoints.
  deny /proc/acpi{,/**} rwklx,
  deny /proc/asound{,/**} rwklx,
  deny /proc/kcore rwklx,
  deny /proc/keys rwklx,
  deny /proc/latency_stats rwklx,
  deny /proc/sched_debug rwklx,
  deny /proc/scsi{,/**} rwklx,
  deny /proc/timer_list rwklx,
  deny /proc/bus/** wklx,
  deny /proc/fs/** wklx,
  deny /proc/irq/** wklx,
  deny /sys/firmware/** rwklx,
  deny /sys/devices/virtual/powercap/** rwklx,
  deny /sys/devices/system/cpu/**/thermal_throttle/** rwklx,
  deny /sys/kernel/security/** rwklx,
  deny mount,
  deny umount,

  /usr/bin/bwrap Px -> lab-codex//lab-codex-bwrap,
  /** ix,
}

profile lab-codex//lab-codex-bwrap flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>

  userns,
  network,
  capability,
  file,
  signal,
  ptrace (readby, tracedby),
  deny /proc/sys/** wklx,
  deny /proc/sysrq-trigger rwklx,
  deny /proc/kcore rwklx,
  deny /proc/kmem rwklx,
  deny /proc/mem rwklx,
  deny /proc/tty/driver/** rwklx,
  deny /proc/acpi{,/**} rwklx,
  deny /proc/asound{,/**} rwklx,
  deny /proc/kcore rwklx,
  deny /proc/keys rwklx,
  deny /proc/latency_stats rwklx,
  deny /proc/sched_debug rwklx,
  deny /proc/scsi{,/**} rwklx,
  deny /proc/timer_list rwklx,
  deny /proc/bus/** wklx,
  deny /proc/fs/** wklx,
  deny /proc/irq/** wklx,
  deny /sys/firmware/** rwklx,
  deny /sys/devices/virtual/powercap/** rwklx,
  deny /sys/devices/system/cpu/**/thermal_throttle/** rwklx,
  deny /sys/kernel/security/** rwklx,
  mount options=(rw, make-rslave) -> **,
  mount options=(rw, make-slave) -> **,
  mount,
  remount,
  umount,
  pivot_root,
  /** ix,
}
