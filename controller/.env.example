# Controller bootstrap env. Operational settings (SMTP, WebDAV, quotas, GPU policy) live in the UI.

# Path to the authoritative SQLite DB (mount a volume here in Docker).
DB_PATH=./data/controller.db

# HTTP + agent-WebSocket port.
PORT=8443

# Public domain the controller is served at: EXACTLY ONE bare hostname, e.g. lab.edwardcheng.net.
# No scheme, port, path, wildcard, or comma-separated list (the server refuses to start otherwise).
# Set this whenever a reverse proxy terminates TLS in front of the controller — without it Next.js
# rejects Server Action POSTs whose Origin doesn't match the internal Host (CSRF protection), and the
# browser Origin / agent WebSocket host are validated against it. Empty → same-origin only (dev).
CONTROLLER_DOMAIN=

# These three secrets are REQUIRED in every environment (dev included) — there are no built-in
# defaults. The app refuses to start without them. Generate real values, e.g.:
#   openssl rand -hex 32

# Required to register an admin on the signup page. Give this only to people allowed to create accounts.
SIGNUP_TOKEN=REPLACE_WITH_RANDOM_SIGNUP_TOKEN

# Fleet secret used to derive every node's per-node token hash, HMAC-SHA256(AGENT_TOKEN, name+token).
# It is NEVER sent to a node; rotating it invalidates all node tokens at once (reprovision afterward).
AGENT_TOKEN=REPLACE_WITH_RANDOM_AGENT_TOKEN

# Secret used to sign admin session cookies. Must be at least 32 characters.
SESSION_SECRET=REPLACE_WITH_openssl_rand_hex_32_value

# OPTIONAL: encrypt controller DB backups at rest on the WebDAV target. Keep this SEPARATE from
# SESSION_SECRET (a leaked session secret then can't decrypt backups). Unset → backups are uploaded
# unencrypted (a warning is logged). Generate with `openssl rand -hex 32`.
BACKUP_KEY=

# OPTIONAL: trust X-Forwarded-* headers for the client IP used in login/signup rate limiting. Set to
# 1 only when a reverse proxy you control sits in front of the controller. It is implied automatically
# whenever CONTROLLER_DOMAIN is set, so you usually don't need this.
TRUST_PROXY=
